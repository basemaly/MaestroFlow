# =============================================================================
# MaestroFlow / DeerFlow — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Production: symlink .env to your shared secrets vault
#   ln -s /path/to/.secrets/agent_keys.env .env
#
# All models route through LiteLLM proxy — no direct API keys required
# in config.yaml. Set up your LiteLLM instance first, then configure below.
# =============================================================================

# =============================================================================
# LiteLLM Proxy (REQUIRED — all 25 configured models use this)
# =============================================================================
LITELLM_PROXY_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_PROXY_API_KEY=sk-roo-local-proxy

# Also set for tools/libraries that read the OpenAI-compatible base URL directly
OPENAI_API_BASE=http://127.0.0.1:4000/v1

# =============================================================================
# Web Search & Fetch Tools
# =============================================================================
TAVILY_API_KEY=your-tavily-api-key
JINA_API_KEY=your-jina-api-key
INFOQUEST_API_KEY=your-infoquest-api-key

# Optional scraping
# FIRECRAWL_API_KEY=your-firecrawl-api-key

# =============================================================================
# Research Registry (Orchestra feature — external deep-research services)
# =============================================================================
# Set any of these to enable the corresponding research tool in subagent prompts.
# Leave unset if you don't have the service running.
# GPT_RESEARCHER_URL=http://localhost:8080       # github.com/assafelovic/gpt-researcher
# PERPLEXICA_URL=http://localhost:3000           # github.com/ItzCrazyKns/Perplexica
# STORM_URL=http://localhost:8085                # github.com/stanford-oval/storm

# =============================================================================
# Direct Model API Keys (only needed if NOT routing through LiteLLM proxy)
# =============================================================================
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key

# =============================================================================
# Observability (optional)
# =============================================================================
# LANGFUSE_TRACING=true
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_ENVIRONMENT=development
# LANGFUSE_RELEASE=local

# =============================================================================
# IM Channel Integrations (optional)
# =============================================================================
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_APP_TOKEN=your-slack-app-token
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
