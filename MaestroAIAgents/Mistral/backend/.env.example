# MaestroFlow Backend Configuration

# ============ OBSERVABILITY - PHASE 1: METRICS INFRASTRUCTURE ============
# Metrics collection
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=60

# Memory monitoring
MEMORY_THRESHOLD_MB=1024

# Connection pool configuration
DB_POOL_MAX_SIZE=10
DB_POOL_IDLE_TIMEOUT_SECONDS=300

# ============ OBSERVABILITY - PHASE 2: LANGFUSE TRACING ============
# Langfuse distributed tracing configuration
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk_xxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk_xxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.io
LANGFUSE_TIMEOUT_SECONDS=30
LANGFUSE_SAMPLE_RATE=1.0

# LLM API CREDENTIALS (for tracing LLM calls)
OPENAI_API_KEY=sk_xxxxxxxxxxxxx
MISTRAL_API_KEY=xxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============ OBSERVABILITY - PHASE 3: ADVANCED MONITORING ============
# Memory tracking
MEMORY_TRACKING_ENABLED=true
MEMORY_GROWTH_RATE_THRESHOLD_MB_MIN=1

# Queue monitoring
QUEUE_TRACKING_ENABLED=true
QUEUE_DEPTH_ALERT_THRESHOLD_PERCENT=80

# Cache monitoring
CACHE_TRACKING_ENABLED=true
CACHE_HIT_RATIO_ALERT_THRESHOLD_PERCENT=20

# Advanced health aggregation
ADVANCED_MONITORING_ENABLED=false
COMPOSITE_HEALTH_ENABLED=true

# ============ OBSERVABILITY - PHASE 4: INTEGRATION & PRODUCTION ============
# Request context propagation
REQUEST_CONTEXT_ENABLED=true

# CORS configuration (for Prometheus scraping from external services)
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9090

# ============ DATABASE ============
DATABASE_URL=sqlite:///.deer-flow/executive.db

# ============ APPLICATION ============
LOG_LEVEL=INFO
